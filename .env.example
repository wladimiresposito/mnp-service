MNP_ENV=dev
MNP_SERVICE_NAME=mnp-service
MNP_VERSION=1.2.0
MNP_RELEASE_NAME=technical-release

# For local demo, false is convenient. For any shared environment, set true.
MNP_REQUIRE_API_KEY=false
MNP_API_KEYS=dev-key-123

MNP_AUDIT_BACKEND=sqlite
MNP_SQLITE_PATH=data/mnp.sqlite
MNP_POSTGRES_DSN=postgresql://mnp:mnp@localhost:5432/mnp

MNP_TENANT_CONFIG_PATH=app/config/tenants.yaml
MNP_MASK_SENSITIVE_FIELDS=true
MNP_SENSITIVE_FIELD_NAMES=password,token,api_key,authorization,cpf,email,phone,telefone,to

# Minimizacao de texto livre na auditoria (item 3): campos com PII/dado
# sensivel sao gravados como hash + comprimento, nao em claro.
MNP_MINIMIZE_FREE_TEXT=true
MNP_FREE_TEXT_FIELD_NAMES=user_text,text,goal,prompt,message,draft_text
# Defina um valor forte e secreto por deployment.
MNP_AUDIT_TEXT_HASH_SALT=change-me-in-production

MNP_DEFAULT_FACT_EXTRACTOR=heuristic
MNP_FACT_CONFIDENCE_THRESHOLD=0.70
MNP_HUMAN_REVIEW_PATH=data/human_review.jsonl

MNP_LLM_BASE_URL=
MNP_LLM_API_KEY=
MNP_LLM_MODEL=gpt-4.1-mini
MNP_LLM_TIMEOUT_SECONDS=30
MNP_LLM_MAX_RETRIES=2
MNP_LLM_RETRY_BACKOFF_SECONDS=0.5

MNP_RAG_KNOWLEDGE_BASE_PATH=app/rag/knowledge_base
MNP_RAG_TOP_K=3
MNP_AGENT_GENERATOR_MODE=mock
MNP_AGENT_SAFE_REWRITE_MODE=deterministic

MNP_ENABLE_SECURITY_HEADERS=true
MNP_ENABLE_REQUEST_ID=true
MNP_CORS_ALLOW_ORIGINS=
MNP_MAX_REQUEST_BODY_BYTES=2000000
